# =============================================================================
# KYC Monaco — Production Environment (XEFI Cloud)
# Copy to .env and fill in real values
# =============================================================================

# Site
SITE_URL=https://kyc.mc

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT Secret (min 32 chars, generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Supabase (self-hosted)
NEXT_PUBLIC_SUPABASE_URL=https://kyc.mc/rest
SUPABASE_ANON_KEY=GENERATE_JWT_WITH_ROLE_ANON

# Storage (MinIO)
MINIO_USER=kycmonaco
MINIO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# SSL (Let's Encrypt or XEFI-provided)
# Place cert.pem and key.pem in ./ssl/
